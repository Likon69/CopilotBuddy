<Window x:Class="CopilotBuddy.UI.ProcessSelectorWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Name="Window"
        Title="Select a WoW"
        Width="310"
        Height="130"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="#FF595959"
        Icon="pack://application:,,,/Resources/bender.ico">
    <Grid x:Name="LayoutRoot">
        <TextBlock HorizontalAlignment="Left"
                   Margin="8,8,0,0"
                   TextWrapping="Wrap"
                   Text="Select the WoW process to attach to:"
                   VerticalAlignment="Top"
                   Foreground="#FFFFFFFF"/>
        <ComboBox x:Name="cbProcesses"
                  Margin="8,28,8,0"
                  VerticalAlignment="Top">
            <ComboBox.ItemContainerStyle>
                <Style TargetType="ComboBoxItem">
                    <Setter Property="Foreground" Value="Black"/>
                </Style>
            </ComboBox.ItemContainerStyle>
        </ComboBox>
        <Button x:Name="btnSelect"
                Content="Select"
                HorizontalAlignment="Left"
                Margin="8,56,0,0"
                VerticalAlignment="Top"
                Width="75"
                Foreground="#FFFFFFFF"
                Background="#FF595959"
                Click="btnSelect_Click"/>
        <Button x:Name="btnCancel"
                Content="Cancel"
                Margin="88,56,0,0"
                VerticalAlignment="Top"
                Width="75"
                HorizontalAlignment="Left"
                IsCancel="True"
                Foreground="#FFFFFFFF"
                Background="#FF595959"
                Click="btnCancel_Click"/>
        <Button x:Name="btnRefresh"
                Content="Refresh"
                HorizontalAlignment="Right"
                Margin="0,56,8,0"
                VerticalAlignment="Top"
                Width="75"
                Foreground="#FFFFFFFF"
                Background="#FF595959"
                Click="btnRefresh_Click"/>
    </Grid>
</Window>
